<launch>
  <arg name="mass" default="1.5"/>
  <arg name="hover_thrust" default="0.7"/>

  <node name="mav_nonlinear_mpc" pkg="mav_nonlinear_mpc" type="nonlinear_mpc_node" respawn="true" clear_params="true" output="screen">
    <remap from="odometry" to="/mavros/local_position/odom" />

    <rosparam file="$(find mav_nonlinear_mpc)/resources/nonlinear_mpc_iris.yaml" />
    <rosparam file="$(find mav_disturbance_observer)/resources/disturbance_observer_iris.yaml"/>

    <param name="verbose" value="true" />

    <param name="mass" value="$(arg mass)"/>
    <param name="hover_thrust" value="$(arg hover_thrust)"/>
    <!-- thrust_normalized_min/max: MAVROS output clamp (0~1 normalized)
         The solver's thrust_min/max come from nonlinear_mpc_iris.yaml via dynamic_reconfigure.
         DO NOT use thrust_min/thrust_max here — it collides with the dynamic_reconfigure key
         and causes the solver to clamp thrust_min == thrust_max == 5.0 (cfg range lower bound),
         which completely disables thrust authority. -->
    <param name="thrust_normalized_min" value="0.0"/>
    <param name="thrust_normalized_max" value="1.0"/>
    <param name="yaw_rate_scale" value="1.0"/>

    <param name="control_rate" value="100.0"/>
    <param name="odom_timeout" value="0.5"/>
    <param name="enable_auto_offboard" value="true"/>
    <param name="enable_auto_arm" value="true"/>
    <param name="offboard_warmup_count" value="50"/>
    <param name="request_interval" value="1.0"/>

    <param name="takeoff_height" value="2.0" />
    <param name="takeoff_point_count" value="3" />
    <param name="takeoff_duration" value="2.5" />
    <param name="geo_fence/x" value="50.0"/>
    <param name="geo_fence/y" value="50.0"/>
    <param name="geo_fence/z" value="6.0"/>

    <param name="state_topic" value="/mavros/state"/>
    <param name="set_mode_service" value="/mavros/set_mode"/>
    <param name="arming_service" value="/mavros/cmd/arming"/>
    <param name="attitude_target_topic" value="/mavros/setpoint_raw/attitude"/>
  </node>
</launch>
