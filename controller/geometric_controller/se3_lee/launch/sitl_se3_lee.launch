<launch>
    <arg name="command_input" default="2" />
    <arg name="gazebo_simulation" default="true" />
    <arg name="visualization" default="true"/>
    <arg name="log_output" default="screen" />
    <arg name="max_acc" default="3" />
    <arg name="max_vel" default="1.5" />
    <arg name="takeoff_height" default="2.0" />
    <arg name="use_dynamic_reconfigure" default="false" />
    
    <node pkg="se3_lee" type="se3_lee_node" name="se3_lee" output="screen">
            <!-- <param name="mav_name" type="string" value="$(arg mav_name)" /> -->
            <remap from="command/bodyrate_command" to="/mavros/setpoint_raw/attitude"/>
            <rosparam file="$(find se3_lee)/config/default.yaml" />
            <param name="ctrl_mode" value="$(arg command_input)" />
            <param name="enable_sim" value="$(arg gazebo_simulation)" />
            <param name="use_dynamic_reconfigure" value="$(arg use_dynamic_reconfigure)" />
            <!-- <param name="posehistory_window" value="0" /> -->
            <!-- <param name="max_acc" value="10.0" /> -->
            <param name="max_acc" value="$(arg max_acc)" />
            <param name="max_vel" value="$(arg max_vel)" />
            <param name="takeoff_height" value="$(arg takeoff_height)" />

            <param name="geo_fence/x" value="100"/>
            <param name="geo_fence/y" value="100"/>
            <param name="geo_fence/z" value="7"/>

            <!-- <param name="debug" value="true"/> -->
    </node>

    <!-- Launch rqt_reconfigure -->
    <group if="$(arg use_dynamic_reconfigure)">
        <node pkg="rqt_reconfigure" type="rqt_reconfigure" output="screen" name="rqt_reconfigure" />
    </group>  
    <!-- <group if="$(arg visualization)">
        <node type="rviz" name="rviz" pkg="rviz" args="-d $(find se3_lee)/launch/config_file.rviz" />
    </group> -->
  
  </launch>
