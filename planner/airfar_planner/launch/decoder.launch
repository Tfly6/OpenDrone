<launch>
    <arg name="graph_topic" default="/planner_nav_graph"/>
    <node pkg="airfar_planner" type="graph_decoder" name="graph_decoder" output="screen">
        <rosparam command="load" file="$(find airfar_planner)/config/graph_decoder.yaml" />
        <remap from="/planner_nav_graph" to="$(arg graph_topic)"/> 
    </node>
    <!-- <node type="rviz" name="decodeRiz" pkg="rviz" args="-d $(find airfar_planner)/rviz/decoder.rviz" /> -->
</launch>