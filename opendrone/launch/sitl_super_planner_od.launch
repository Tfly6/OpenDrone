<launch>
    <arg name="use_mpc" default="false" />
    <arg name="odom_topic" default="/mavros/local_position/odom" />
    <arg name="lidar_topic" default="/livox/lidar" />
    <arg name="lidar_frame" default="livox_link" />
    <arg name="super_cfg" default="$(find super_planner_od)/config/click_smooth_px4.yaml" />
    
    <node pkg="tf" type="static_transform_publisher" name="world_map_linker" args="0 0 0 0 0 0 world map 100" />
    <node pkg="tf" type="static_transform_publisher" name="tf_lidar" args="0.07 0 0.072 0 0.3925 0 base_link livox_link 50"/>

    <node pkg="opendrone" name="pointcloud_to_world" type="pointcloud_to_world.py" output="screen">
        <param name="source_topic" value="$(arg lidar_topic)" />
        <param name="output_topic" value="/registered_scan" />
        <param name="source_frame" value="$(arg lidar_frame)" />
        <param name="target_frame" value="world" />
        <param name="cloud_timeout" value="2.0" />
        <param name="filter_enable" value="false" />
    </node>

    <include file="$(find super_planner_od)/launch/super_planner_od.launch">
        <arg name="config_path" value="$(arg super_cfg)" />
        <arg name="use_rviz" value="false" />
    </include>

    <group if="$(arg use_mpc)">
        <node pkg="opendrone" name="traj_msg_converter" type="trajectory_msg_converter.py" output="screen">
            <param name="planner_bspline_topic" value="/planning_cmd/poly_traj"/>
            <param name="publish_horizon_points" value="60"/>
            <param name="publish_dt" value="0.02"/>
            <param name="traj_pub_topic" value="/command/trajectory"/>
        </node>
    </group>

    <group unless="$(arg use_mpc)">
        <node pkg="opendrone" name="traj_msg_converter" type="trajectory_msg_converter.py" output="screen">
            <param name="planner_traj_topic" value="/planning/pos_cmd"/>
            <param name="traj_pub_topic" value="/command/trajectory"/>
        </node>
    </group>

    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find super_planner_od)/rviz/bench.rviz" required="true" />
</launch>
