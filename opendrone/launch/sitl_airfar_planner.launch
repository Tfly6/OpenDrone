<launch>
    <arg name="odom_topic" default="/mavros/local_position/odom" />
    <arg name="camera_depth_topic" default="/camera/depth/points" />
    <arg name="config_file" default="default" />

    <!-- Static transforms: world -> base_link -> camera_link -->
    <!-- <node pkg="tf" type="static_transform_publisher" name="world_map_linker"
          args="0 0 0 0 0 0 world map 100" /> -->
    <node pkg="tf" type="static_transform_publisher" name="tf_camera"
          args="0.1 0 0.0 -1.57 0 -1.57 base_link camera_link 33"/>

    <!-- Depth camera processor: adds intensity + transforms to world frame -->
    <node pkg="opendrone" name="depth_camera_processor"
          type="depth_camera_processor" output="screen">
        <param name="input_topic" value="$(arg camera_depth_topic)" />
        <param name="output_topic" value="/scan_cloud" />
        <param name="target_frame" value="map" />
        <param name="source_frame" value="camera_link" />
        <param name="intensity_value" value="255.0" />
    </node>

    <!-- Air-FAR Planner -->
    <include file="$(find airfar_planner)/launch/airfar.launch">
        <arg name="odom_topic" value="$(arg odom_topic)" />
        <arg name="terrain_cloud_topic" value="/scan_cloud" />
        <arg name="terrain_local_topic" value="/terrain_local_cloud" />
        <arg name="scan_cloud_topic" value="/scan_cloud" />
        <arg name="config_file" value="$(arg config_file)" />
    </include>

    <!-- Waypoint to trajectory converter -->
    <node pkg="opendrone" name="waypoint_msg_converter"
          type="waypoint_msg_converter.py" output="screen">
        <param name="waypoint_topic" value="/way_point" />
        <param name="traj_pub_topic" value="/command/trajectory" />
    </node>

    <!-- RViz -->
    <node name="rviz" pkg="rviz" type="rviz"
          args="-d $(find opendrone)/rviz/airfar_planner.rviz" required="true" />
</launch>