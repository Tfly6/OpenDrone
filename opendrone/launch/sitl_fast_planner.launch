<launch>
    <arg name="use_mpc" default="false" />
    <!-- Planner configs -->
    <arg name="use_kino_planner" default="true" />
    <arg name="map_size_x" default="40.0"/>
    <arg name="map_size_y" default="40.0"/>
    <arg name="map_size_z" default=" 5.0"/>

    <arg name="odom_topic" default="/mavros/local_position/odom" />
    <arg name="camera_pose_topic" default="/camera/pose"/>
    <arg name="depth_topic" default="/camera/depth/image_raw"/>

    <arg name="max_vel" default="1.0" />
    <arg name="max_acc" default="2.5" />

    <!-- ROS static transformation -->
    <node pkg="tf" type="static_transform_publisher" name="world_map_linker" args="0 0 0 0 0 0 world map 100" />
    <node pkg="tf" type="static_transform_publisher" name="tf_camera" args="0.1 0 0.0 -1.57 0 -1.57 base_link camera_link 33"/>
    
    <!-- Camera pose publisher -->
    <!-- This node publishes tf from parent_frame to child_frame-->
    <node pkg="opendrone" name="camera_pose_publisher" type="camera_pose_publisher.py" output="screen">
        <param name="parent_frame" value="world" />
        <param name="child_frame" value="camera_link" />
        <param name="pose_topic" value="camera/pose" />
    </node>

    <!-- Fast planner -->
    <include unless="$(arg use_kino_planner)" file="$(find fast_planner)/launch/topo_replan.launch" >
        <arg name="map_size_x" default="$(arg map_size_x)"/>
        <arg name="map_size_y" default="$(arg map_size_y)"/>
        <arg name="map_size_z" default="$(arg map_size_z)"/>

        <arg name="odom_topic" default="$(arg odom_topic)" />
        <arg name="depth_topic" default="$(arg depth_topic)"/>
        <arg name="camera_pose_topic" default="$(arg camera_pose_topic)"/>
        <arg name="max_vel" default="$(arg max_vel)"/>
        <arg name="max_acc" default="$(arg max_acc)"/>

        <arg name="cx" value="320"/>
        <arg name="cy" value="240"/>
        <arg name="fx" value="319.9348449707031"/>
        <arg name="fy" value="319.9348449707031"/>
    </include>

    <include if="$(arg use_kino_planner)" file="$(find fast_planner)/launch/kino_replan.launch" >
        <arg name="map_size_x" default="$(arg map_size_x)"/>
        <arg name="map_size_y" default="$(arg map_size_y)"/>
        <arg name="map_size_z" default="$(arg map_size_z)"/>

        <arg name="odom_topic" default="$(arg odom_topic)" />
        <arg name="depth_topic" default="$(arg depth_topic)"/>
        <arg name="camera_pose_topic" default="$(arg camera_pose_topic)"/>
        <arg name="max_vel" default="$(arg max_vel)"/>
        <arg name="max_acc" default="$(arg max_acc)"/>

        <arg name="cx" value="320"/>
        <arg name="cy" value="240"/>
        <arg name="fx" value="319.9348449707031"/>
        <arg name="fy" value="319.9348449707031"/>
    </include>

    <!-- 当 use_mpc 为 true 时 -->
    <group if="$(arg use_mpc)">
        <node pkg="opendrone" name="traj_msg_converter" type="trajectory_msg_converter.py" output="screen">
            <param name="planner_bspline_topic" value="/planning/bspline"/>
            <param name="publish_horizon_points" value="60"/>
            <param name="publish_dt" value="0.02"/>
            <param name="traj_pub_topic" value="/command/trajectory"/>
        </node>
    </group>

    <!-- 当 use_mpc 为 false 时 -->
    <group unless="$(arg use_mpc)">
        <node pkg="opendrone" name="traj_msg_converter" type="trajectory_msg_converter.py" output="screen">
            <param name="planner_traj_topic" value="/planning/pos_cmd"/>
            <param name="traj_pub_topic" value="/command/trajectory"/>
        </node>
    </group>
 
    <!-- Rviz -->
    <node type="rviz" name="rviz" pkg="rviz" args="-d $(find opendrone)/rviz/fast-planner.rviz" />

</launch>