<?xml version="1.0" encoding="utf-8"?>
<launch>
  <arg name="enable_sim" default="true"/>
  <arg name="takeoff_height" default="2.0"/>
  <arg name="mass" default="1.5"/>
  <arg name="hover_thrust" default="0.7"/>
  <arg name="use_dynamic_reconfigure" default="false"/>
  <!-- <arg name="init_pose_x" default="0.0"/>
  <arg name="init_pose_y" default="0.0"/>
  <arg name="init_pose_z" default="0.5"/> -->

  <node pkg="lqr_controller" type="lqr_controller_node" name="lqr_controller_node" output="screen" respawn="true" clear_params="true">
    <rosparam file="$(find lqr_controller)/config/default.yaml"/>
    <param name="enable_sim" value="$(arg enable_sim)"/>
    <param name="use_dynamic_reconfigure" value="$(arg use_dynamic_reconfigure)"/>
    <param name="takeoff_height" value="$(arg takeoff_height)"/>
    <param name="mass" value="$(arg mass)"/>
    <param name="hover_thrust" value="$(arg hover_thrust)"/>
    <!-- <param name="init_pose_x" value="$(arg init_pose_x)"/>
    <param name="init_pose_y" value="$(arg init_pose_y)"/>
    <param name="init_pose_z" value="$(arg init_pose_z)"/> -->

    <!-- Geofence parameters -->
    <param name="geo_fence/x" value="50.0"/>
    <param name="geo_fence/y" value="50.0"/>
    <param name="geo_fence/z" value="6.0"/>
  </node>
  <group if="$(arg use_dynamic_reconfigure)">
    <node pkg="rqt_reconfigure" type="rqt_reconfigure" output="screen" name="rqt_reconfigure" />
  </group>
</launch>
