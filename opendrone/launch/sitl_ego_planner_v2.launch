<launch>
    <arg name="use_mpc" default="false" />
    <node pkg="tf" type="static_transform_publisher" name="world_map_linker" args="0 0 0 0 0 0 world map 100" />
    <node pkg="tf" type="static_transform_publisher" name="tf_camera" args="0.1 0 0.0 -1.57 0 -1.57 base_link camera_link 33"/>

    <!-- Camera pose publisher -->
    <!-- This node publishes tf from parent_frame to child_frame-->
    <node pkg="opendrone" name="camera_pose_publisher" type="camera_pose_publisher.py" output="screen">
        <param name="parent_frame" value="world" />
        <param name="child_frame" value="camera_link" />
        <param name="pose_topic" value="camera/pose" />
    </node>

     <include file="$(find ego_planner_v2)/launch/include/run_in_sim.xml">
        <arg name="drone_id" value="0"/>
        <arg name="map_size_x" value="100"/>
        <arg name="map_size_y" value="100"/>
        <arg name="map_size_z" value="10"/>
        <arg name="odom_topic" value="mavros/local_position/odom"/>
        <arg name="camera_pose_topic" value="camera/pose"/>
        <arg name="depth_topic" value="camera/depth/image_raw"/>
        <arg name="max_vel" value="1.5" />
        <arg name="max_acc" value="6.0" />
        <arg name="flight_type" value="1"/>
    </include>

    <!-- Relay odom topic: mavros -> drone_0_mavros -->
    <node pkg="topic_tools" type="relay" name="drone_0_odom_relay" args="/mavros/local_position/odom /drone_0_mavros/local_position/odom" />
    <node pkg="topic_tools" type="relay" name="drone_0_camera_pose_relay" args="/camera/pose /drone_0_camera/pose" />
    <node pkg="topic_tools" type="relay" name="drone_0_depth_relay" args="/camera/depth/image_raw /drone_0_camera/depth/image_raw" />
    <!-- 当 use_mpc 为 true 时 -->
    <group if="$(arg use_mpc)">
        <node pkg="opendrone" name="traj_msg_converter" type="trajectory_msg_converter.py" output="screen">
            <param name="planner_bspline_topic" value="/drone_0_planning/bspline"/>
            <param name="publish_horizon_points" value="60"/>
            <param name="publish_dt" value="0.02"/>
            <param name="traj_pub_topic" value="/command/trajectory"/>
        </node>
    </group>

    <!-- 当 use_mpc 为 false 时 -->
    <group unless="$(arg use_mpc)">
        <node pkg="opendrone" name="traj_msg_converter" type="trajectory_msg_converter.py" output="screen">
            <param name="planner_traj_topic" value="/drone_0_planning/pos_cmd"/>
            <param name="traj_pub_topic" value="/command/trajectory"/>
        </node>
    </group>
    
    <!-- rviz -->
    <!-- <node name="rviz" pkg="rviz" type="rviz" args="-d $(find opendrone)/rviz/rviz_ego.rviz" required="true" /> -->
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find opendrone)/rviz/ego_planner_v2.rviz" required="true" />
</launch>